# Shared
NODE_ENV=development

# Treemich API
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:54321/treemich
IMMICH_BASE_URL=http://localhost:2283/api
IMMICH_PEOPLE_PAGE_SIZE=1000
TREEMICH_ENCRYPTION_KEY=replace-with-64-char-hex-key
TREEMICH_SESSION_COOKIE_NAME=treemich_session
TREEMICH_SESSION_TTL_MS=2592000000
WEB_ORIGIN=http://localhost:5173
RATE_LIMIT_MAX=300
RATE_LIMIT_TIME_WINDOW_MS=60000

# Treemich Web (build-time)
VITE_TREEMICH_API_URL=/api

# Docker Compose notes:
# - DATABASE_URL is overridden inside docker-compose.yml (points to the postgres container).
# - If Immich runs on the host, set IMMICH_BASE_URL=http://host.docker.internal:2283/api
# - For docker compose, set WEB_ORIGIN=http://localhost:8080
# - Generate TREEMICH_ENCRYPTION_KEY with: openssl rand -hex 32
