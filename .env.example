# Shared
NODE_ENV=development

# Treemich API
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:54321/treemich
# Immich URL must be reachable FROM the Treemich API process:
# - npm run dev (API on host): http://localhost:2283/api
# - Docker Compose (API in container, Immich on host): http://host.docker.internal:2283/api
# - Immich also in Docker on same compose network: use that service URL (e.g. http://immich-server:2283/api)
IMMICH_BASE_URL=http://localhost:2283/api
IMMICH_PEOPLE_PAGE_SIZE=1000
TREEMICH_ENCRYPTION_KEY=replace-with-64-char-hex-key
TREEMICH_SESSION_COOKIE_NAME=treemich_session
TREEMICH_SESSION_TTL_MS=2592000000
WEB_ORIGIN=http://localhost:5173
RATE_LIMIT_MAX=300
RATE_LIMIT_TIME_WINDOW_MS=60000
# Optional. Set to false / 0 / off to disable the full-tree GET /tree/validation engine; per-person checks stay available.
# TREEMICH_VALIDATION_ENGINE_ENABLED=true
# Optional. Set to false / 0 / off to disable map places feed used by Phase 2 map UI.
# MAP_UI_ENABLED=true
# Optional. Set to false / 0 / off to disable automatic birth place geocoding from profile Birth city/country edits.
# TREEMICH_PROFILE_PLACE_GEOCODING_ENABLED=true
# Optional. Set to false / 0 / off to disable `/families` HTTP routes (including family life events).
# TREEMICH_FAMILY_MODEL_ENABLED=true
# Optional. Set to false / 0 / off to disable GET /export/gedcom (Phase 5a GEDCOM export).
# TREEMICH_GEDCOM_EXPORT_ENABLED=true
# Phase 5b GEDCOM import (POST /import/gedcom/*). Default when unset: disabled — set to true/1/on to enable.
# TREEMICH_GEDCOM_IMPORT_ENABLED=false
# Optional byte cap for import JSON body (default 3_000_000).
# TREEMICH_GEDCOM_IMPORT_MAX_BYTES=3000000
# Optional parser line cap (default 250000).
# TREEMICH_GEDCOM_IMPORT_MAX_LINES=250000

# Treemich Web (build-time)
VITE_TREEMICH_API_URL=/api
# Optional. Set to "false" to hide the People sidebar blocks for evidence repositories, sources, merge, and media registry.
# VITE_EVIDENCE_MANAGEMENT_UI=true

# Docker Compose notes:
# - DATABASE_URL is overridden inside docker-compose (postgres service).
# - WEB_ORIGIN must be the browser URL (e.g. http://localhost:8080), not Vite’s 5173.
# - Generate TREEMICH_ENCRYPTION_KEY with: openssl rand -hex 32
# - Feature flags (MAP_UI_*, TREEMICH_GEDCOM_*, family/validation, etc.) are forwarded from this file into
#   the `api` service via docker-compose.yml — if you add a new TREEMICH_* toggle, add it there too or the
#   container will not see it (the API image does not bundle the repo `.env`).
