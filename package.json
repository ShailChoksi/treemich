{
  "name": "treemich",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "prisma": {
    "schema": "apps/api/prisma/schema.prisma"
  },
  "scripts": {
    "prisma:generate": "prisma generate",
    "build": "npm run build -w @treemich/api && npm run build -w @treemich/web",
    "dev": "concurrently -n api,web -c cyan,magenta \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run dev -w @treemich/api",
    "dev:web": "npm run dev -w @treemich/web",
    "test": "npm run test -w @treemich/api && npm run test -w @treemich/web",
    "lint": "eslint . --max-warnings=0 && prettier --check . && npm run lint -w @treemich/api && npm run lint -w @treemich/web && npm run lint -w @treemich/shared"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "overrides": {
    "tar": "7.5.13",
    "minimatch": "10.2.5",
    "vite": "8.0.9",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.37.0",
    "prettier": "^3.6.2",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tar": "7.5.13"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.34",
    "@prisma/client": "^6.19.3",
    "bidi-js": "^1.0.3",
    "react-use-measure": "^2.1.7",
    "troika-worker-utils": "^0.52.0",
    "webgl-sdf-generator": "^1.1.1"
  }
}
